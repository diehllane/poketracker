rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write only their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can read/write only their own daycare entries
      match /daycare/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Users can read/write only their own loan entries
      match /loans/{loanId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
